{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./packages",
    "types": ["node"],
    "paths": {
      "@pi-web/bridge": ["./packages/bridge"],
      "@pi-web/bridge/*": ["./packages/bridge/*"]
    }
  },
  "include": ["packages/bridge/**/*.ts", "packages/bin/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
