{
  "name": "@woxqaq/pi-web",
  "version": "0.2.2",
  "description": "Web Shell for pi coding agent",
  "keywords": [
    "pi",
    "pi-coding-agent",
    "pi-package"
  ],
  "license": "MIT",
  "repository": {
    "url": "https://github.com/woxQAQ/pi-web"
  },
  "files": [
    "dist/bin",
    "dist/bridge",
    "web-dist",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:server": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "build:web": "pnpm -C packages/web build",
    "build": "pnpm run build:server && pnpm run build:web",
    "check": "tsgo --noEmit",
    "dev:pi": "PI_BRIDGE_PORT=${PI_BRIDGE_PORT:-8080} pi -e ./packages/bin/index.ts",
    "dev:pi:inspect": "PI_BRIDGE_PORT=${PI_BRIDGE_PORT:-8080} NODE_OPTIONS='--inspect-brk' pi -e ./packages/bin/index.ts",
    "dev:web": "pnpm -C packages/web dev",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepack": "npm run build:server && npm run build:web",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "@types/node": "^24.3.0",
    "@typescript/native-preview": "7.0.0-dev.20260413.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "pi": {
    "extensions": [
      "./dist/bin/index.js"
    ]
  }
}
